{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"strict": true,
		"jsx": "preserve",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"importHelpers": true,
		"allowSyntheticDefaultImports": true,
		"useDefineForClassFields": true,
		"resolveJsonModule": true,
		"lib": ["esnext", "dom"],
		"types": ["@dcloudio/types", "miniprogram-api-typings", "uni-app"],
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src/**/*.ts", "src/*.ts", "src/**/*.d.ts", "src/**/*.vue", "src/*/*.vue"],
	"exclude": ["node_modules", "unpackage", "src/**/*.nvue"]
}